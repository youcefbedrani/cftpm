# ============================================================================
# Copy this file to .env, then fill in real values.
# Never commit .env to git — it is listed in .gitignore.
# ============================================================================

# ---- Postgres (used by both the db container and the app container) ----
POSTGRES_DB=cftmp
POSTGRES_USER=cftmp
POSTGRES_PASSWORD=change-me-please-strong-password

# ---- Auth ----
# A long random string used to sign session cookies (JWTs).
# Generate one with: openssl rand -hex 48
AUTH_SECRET=replace-with-output-of-openssl-rand-hex-48

# ---- Seed admin (created by `npm run db:seed`) ----
ADMIN_EMAIL=admin@cftmp.com
ADMIN_PASSWORD=ChangeThisAdminPassword!2026
ADMIN_NAME=CFTMP Admin

# ---- Production database (Supabase / cloud Postgres) ----
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# DATABASE_USE_SSL=true

# ---- Local-dev only (the docker-compose app uses DATABASE_URL above) ----
# When you run `npm run dev` from your laptop against the Docker postgres,
# uncomment and use this:
# DATABASE_URL=postgres://cftmp:change-me-please-strong-password@127.0.0.1:5432/cftmp

# ---- AI Chat ----
GROQ_API_KEY=
